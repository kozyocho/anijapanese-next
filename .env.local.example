# .env.local — fill in your credentials

# Supabase (database only — auth is handled by Clerk)
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Clerk (authentication)
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY
CLERK_SECRET_KEY=sk_test_YOUR_KEY

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Optional: for pgvector embeddings
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Stripe (payments / freemium)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
# Webhook secret — get from: stripe listen --print-secret (local) or Stripe Dashboard (production)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# Price IDs — create recurring and one-time products at: https://dashboard.stripe.com/products
STRIPE_MONTHLY_PRICE_ID=price_YOUR_MONTHLY_PRICE_ID      # $4.99/month recurring
STRIPE_ANNUAL_PRICE_ID=price_YOUR_ANNUAL_PRICE_ID        # $29.99/year recurring
STRIPE_LIFETIME_PRICE_ID=price_YOUR_LIFETIME_PRICE_ID    # $59.99 one-time payment

# Welcome offer (24h sale on Lifetime plan only)
STRIPE_LIFETIME_SALE_PRICE_ID=price_YOUR_LIFETIME_SALE_PRICE_ID  # $39.99 one-time (optional)

# App URL (used in Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
